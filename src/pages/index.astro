---
import Slide1 from '../assets/the-grey.png';
import Slide2 from '../assets/chapter-10.png';
import Slide3 from '../assets/chapter-5.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-slider" aria-label="Trang chu">
				<div class="slides">
					<article class="slide" style={`background-image: url(${Slide1.src});`}>
						<div class="overlay"></div>
						<div class="content">
							<p class="subtitle">Bí ẩn về UFO và Người ngoài hành tinh</p>
							<h1>ALIEN INTERVIEW</h1>
							<p class="desc">Điều gì đúng với bạn, thì nó đúng với bạn</p>
							<div class="actions">
								<a href="/blog/alien-interview" class="btn btn-line">Đọc ngay</a>
							</div>
						</div>
					</article>
					<article class="slide" style={`background-image: url(${Slide2.src});`}>
						<div class="overlay"></div>
						<div class="content">
							<p class="subtitle">ALIEN INTERVIEW</p>
							<h1>CHAPTER 10</h1>
							<p class="desc">Một bài học về sinh học</p>
							<div class="actions">
								<a href="blog/nguon-goc-su-song-va-ky-nghe-sinh-hoc-vu-tru/" class="btn btn-line">Đọc ngay</a>
							</div>
						</div>
					</article>
					<article class="slide" style={`background-image: url(${Slide3.src});`}>
						<div class="overlay"></div>
						<div class="content">
							<p class="subtitle">ALIEN INTERVIEW</p>
							<h1>CHAPTER 5</h1>
							<p class="desc">Hành trình tiếp nhận ngôn ngữ và trí thức của Airl</p>
							<div class="actions">
								<a href="blog/hanh-trinh-tiep-nhan-ngon-ngu-va-tri-thuc-cua-airl/" class="btn btn-line">Đọc ngay</a>
							</div>
						</div>
					</article>
				</div>
				<div class="slider-nav">
					<button class="nav-button prev" type="button" aria-label="Slide trước">‹</button>
					<button class="nav-button next" type="button" aria-label="Slide tiếp theo">›</button>
				</div>
				<div class="pagination" role="tablist" aria-label="Điều hướng slide">
					<button class="pagination-dot active" type="button" aria-label="Slide 1" aria-selected="true"></button>
					<button class="pagination-dot" type="button" aria-label="Slide 2" aria-selected="false"></button>
					<button class="pagination-dot" type="button" aria-label="Slide 3" aria-selected="false"></button>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			(function () {
				const slides = document.querySelector('.slides');
				const dots = Array.from(document.querySelectorAll('.pagination-dot'));
				const prevButton = document.querySelector('.nav-button.prev');
				const nextButton = document.querySelector('.nav-button.next');
				let currentIndex = 0;
				const totalSlides = dots.length;
				let timeout;

				function updateSlider(index) {
					currentIndex = (index + totalSlides) % totalSlides;
					slides.style.transform = `translateX(-${currentIndex * (100 / totalSlides)}%)`;
					dots.forEach((dot, dotIndex) => {
						dot.classList.toggle('active', dotIndex === currentIndex);
						dot.setAttribute('aria-selected', dotIndex === currentIndex ? 'true' : 'false');
					});
				}

				function startAutoplay() {
					clearTimeout(timeout);
					timeout = setTimeout(() => updateSlider(currentIndex + 1), 6000);
				}

				dots.forEach((dot, index) => {
					dot.addEventListener('click', () => {
						updateSlider(index);
						startAutoplay();
					});
				});

				prevButton.addEventListener('click', () => {
					updateSlider(currentIndex - 1);
					startAutoplay();
				});

				nextButton.addEventListener('click', () => {
					updateSlider(currentIndex + 1);
					startAutoplay();
				});

				const slider = document.querySelector('.hero-slider');
				slider.addEventListener('mouseenter', () => clearTimeout(timeout));
				slider.addEventListener('mouseleave', startAutoplay);

				updateSlider(0);
				startAutoplay();
			})();
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 100%;
		padding: 0;
		margin: 0;
	}
	.hero-slider {
		position: relative;
		width: 100%;
		height: clamp(420px, 78vh, 760px);
		overflow: hidden;
	}
	.slides {
		display: flex;
		width: 300%;
		height: 100%;
		transform: translateX(0);
		transition: transform 0.8s ease;
	}
	.slide {
		position: relative;
		width: 33.3333%;
		height: 100%;
		background-size: cover;
		background-position: center;
	}
	.overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
	}
	.content {
		position: relative;
		z-index: 1;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		color: #fff;
		padding: 1.5rem;
	}
	.subtitle {
		font-size: 1.1rem;
		margin-bottom: 0.75rem;
	}
	h1 {
		color: #fff;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1.08;
		margin-bottom: 0.8rem;
	}
	.desc {
		font-size: 1.2rem;
		max-width: 680px;
		margin-bottom: 1.3rem;
	}
	.actions {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
		justify-content: center;
	}
	.btn {
		padding: 0.75rem 1.35rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 700;
		border: 1px solid transparent;
	}
	.btn-solid {
		background: #0bb08b;
		color: #fff;
	}
	.btn-line {
		border-color: rgba(255, 255, 255, 0.8);
		color: #fff;
	}
	.slider-nav {
		position: absolute;
		top: 50%;
		left: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1rem;
		pointer-events: none;
	}

	.nav-button {
		pointer-events: all;
		border: none;
		background: rgba(0, 0, 0, 0.35);
		color: #fff;
		width: 48px;
		height: 48px;
		border-radius: 999px;
		font-size: 1.75rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s ease;
	}

	.nav-button:hover {
		background: rgba(0, 0, 0, 0.55);
	}

	.pagination {
		position: absolute;
		bottom: 1.4rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.65rem;
	}

	.pagination-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.8);
		background: rgba(255, 255, 255, 0.2);
		cursor: pointer;
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.pagination-dot.active {
		background: #fff;
		transform: scale(1.15);
	}

	@media (max-width: 720px) {
		.hero-slider {
			height: 72vh;
		}
		.desc {
			font-size: 1rem;
		}
		.slider-nav {
			padding: 0 0.5rem;
		}
		.nav-button {
			width: 42px;
			height: 42px;
			font-size: 1.5rem;
		}
	}
	@media (max-width: 720px) {
		.hero-slider {
			height: 72vh;
		}
		.desc {
			font-size: 1rem;
		}
	}
</style>

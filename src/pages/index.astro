---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.heroImage)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPost = posts[0];
const chapter9Slug = 'lich-su-trai-dat-va-bi-mat-cua-the-domain';
const chapter9Post = posts.find((post) => post.id === chapter9Slug);
const dailySeed = new Date().toISOString().slice(0, 10);

function hashString(value: string) {
	return [...value].reduce((hash, character) => (hash * 31 + character.charCodeAt(0)) >>> 0, 0);
}

const usedIds = new Set([latestPost?.id, chapter9Post?.id].filter(Boolean));
const randomPool = posts.filter((post) => !usedIds.has(post.id));

const randomPost = randomPool
	.map((post) => ({
		post,
		score: hashString(`${dailySeed}-${post.id}`),
	}))
	.sort((a, b) => a.score - b.score)
	.at(0)?.post;

const slidePosts = [latestPost, chapter9Post, randomPost].filter(Boolean);
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/LOGO_NEWS.png" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-slider" aria-label="Trang chủ">
				<div class="slides">
					{
						slidePosts.map((post, index) => (
							<article class="slide" style={`background-image: url(${post.data.heroImage?.src});`}>
								<div class="overlay" />
								<div class="content">
									<p class="subtitle">{index === 0 ? 'Bài mới nhất' : 'Gợi ý đọc tiếp'}</p>
									<h1>{post.data.title}</h1>
									<p class="desc">{post.data.description}</p>
									<div class="actions">
										<a href={`/news/${post.id}/`} class="btn btn-line">
											Đọc ngay
										</a>
									</div>
								</div>
							</article>
						))
					}
				</div>
				<div class="slider-nav">
					<button class="nav-button prev" type="button" aria-label="Slide trước">‹</button>
					<button class="nav-button next" type="button" aria-label="Slide tiếp theo">›</button>
				</div>
				<div class="pagination" role="tablist" aria-label="Điều hướng slide">
					{
						slidePosts.map((_, index) => (
							<button
								class:list={['pagination-dot', { active: index === 0 }]}
								type="button"
								aria-label={`Slide ${index + 1}`}
								aria-selected={index === 0 ? 'true' : 'false'}
							>
							</button>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
		<script>
			(function () {
				const slides = document.querySelector('.slides');
				const dots = Array.from(document.querySelectorAll('.pagination-dot'));
				const prevButton = document.querySelector('.nav-button.prev');
				const nextButton = document.querySelector('.nav-button.next');
				let currentIndex = 0;
				const totalSlides = dots.length;
				let timeout;

				function updateSlider(index) {
					currentIndex = (index + totalSlides) % totalSlides;
					slides.style.transform = `translateX(-${currentIndex * (100 / totalSlides)}%)`;
					dots.forEach((dot, dotIndex) => {
						dot.classList.toggle('active', dotIndex === currentIndex);
						dot.setAttribute('aria-selected', dotIndex === currentIndex ? 'true' : 'false');
					});
				}

				function startAutoplay() {
					clearTimeout(timeout);
					timeout = setTimeout(() => updateSlider(currentIndex + 1), 6000);
				}

				dots.forEach((dot, index) => {
					dot.addEventListener('click', () => {
						updateSlider(index);
						startAutoplay();
					});
				});

				prevButton.addEventListener('click', () => {
					updateSlider(currentIndex - 1);
					startAutoplay();
				});

				nextButton.addEventListener('click', () => {
					updateSlider(currentIndex + 1);
					startAutoplay();
				});

				const slider = document.querySelector('.hero-slider');
				slider.addEventListener('mouseenter', () => clearTimeout(timeout));
				slider.addEventListener('mouseleave', startAutoplay);

				updateSlider(0);
				startAutoplay();
			})();
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 100%;
		padding: 0;
		margin: 0;
	}
	.hero-slider {
		position: relative;
		width: 100%;
		height: clamp(420px, 78vh, 760px);
		overflow: hidden;
	}
	.slides {
		display: flex;
		width: 300%;
		height: 100%;
		transform: translateX(0);
		transition: transform 0.8s ease;
	}
	.slide {
		position: relative;
		width: 33.3333%;
		height: 100%;
		background-size: cover;
		background-position: center;
	}
	.overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
	}
	.content {
		position: relative;
		z-index: 1;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		color: #fff;
		padding: 1.5rem;
	}
	.subtitle {
		font-size: 1.1rem;
		margin-bottom: 0.75rem;
	}
	h1 {
		color: #fff;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1.08;
		margin-bottom: 0.8rem;
	}
	.desc {
		font-size: 1.2rem;
		max-width: 680px;
		margin-bottom: 1.3rem;
	}
	.actions {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
		justify-content: center;
	}
	.btn {
		padding: 0.75rem 1.35rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 700;
		border: 1px solid transparent;
	}
	.btn-solid {
		background: #0bb08b;
		color: #fff;
	}
	.btn-line {
		border-color: rgba(255, 255, 255, 0.8);
		color: #fff;
	}
	.slider-nav {
		position: absolute;
		top: 50%;
		left: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1rem;
		pointer-events: none;
	}

	.nav-button {
		pointer-events: all;
		border: none;
		background: rgba(0, 0, 0, 0.35);
		color: #fff;
		width: 48px;
		height: 48px;
		border-radius: 999px;
		font-size: 1.75rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s ease;
	}

	.nav-button:hover {
		background: rgba(0, 0, 0, 0.55);
	}

	.pagination {
		position: absolute;
		bottom: 1.4rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.65rem;
	}

	.pagination-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.8);
		background: rgba(255, 255, 255, 0.2);
		cursor: pointer;
		transition:
			transform 0.2s ease,
			background 0.2s ease;
	}

	.pagination-dot.active {
		background: #fff;
		transform: scale(1.15);
	}

	@media (max-width: 720px) {
		.hero-slider {
			height: 72vh;
		}
		.desc {
			font-size: 1rem;
		}
		.slider-nav {
			padding: 0 0.5rem;
		}
		.nav-button {
			width: 42px;
			height: 42px;
			font-size: 1.5rem;
		}
	}
</style>

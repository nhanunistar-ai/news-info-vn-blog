---
import type { GetStaticPaths } from 'astro';
import CategoryIndex from '~/components/blog/CategoryIndex.astro';
import { getCategoryItems } from '~/utils/seriesList';
import { APP_BLOG } from 'astrowind:config';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  const categoryPosts = await getCategoryItems('study');

  return paginate(categoryPosts, {
    pageSize: APP_BLOG?.postsPerPage || 10,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---
<CategoryIndex
  categorySlug="study"
  categoryName="Study"
  description="Các chuỗi nghiên cứu, bài học nền tảng và ghi chú học tập trên news.info.vn."
  posts={page.data}
  page={page.currentPage}
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
/>

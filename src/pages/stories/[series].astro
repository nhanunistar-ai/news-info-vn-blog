---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { isPublishedPost } from '../../lib/posts';

export async function getStaticPaths() {
	const seriesEntries = await getCollection('series');
	const posts = await getCollection('blog', ({ data }) => isPublishedPost(data) && data.category === 'stories');

	return seriesEntries.map((series) => {
		const chapters = posts
			.filter((post) => post.data.series === series.id)
			.sort(
				(a, b) =>
					(a.data.chapter ?? Number.MAX_SAFE_INTEGER) - (b.data.chapter ?? Number.MAX_SAFE_INTEGER) ||
					a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
			);

		return {
			params: { series: series.id },
			props: { series, chapters },
		};
	});
}

type Props = {
	series: CollectionEntry<'series'>;
	chapters: CollectionEntry<'blog'>[];
};

const { series, chapters } = Astro.props as Props;
const { Content } = await render(series);
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead
			title={`${series.data.title} | ${SITE_TITLE}`}
			description={series.data.description}
			image={series.data.coverImage}
		/>
		<style>
			main {
				width: min(1020px, calc(100% - 2em));
			}
			.book-hero {
				display: grid;
				grid-template-columns: minmax(260px, 420px) 1fr;
				gap: 2rem;
				align-items: center;
				margin-bottom: 2.5rem;
			}
			.book-hero img {
				width: 100%;
				aspect-ratio: 3 / 4;
				object-fit: cover;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.book-copy h1 {
				margin-bottom: 0.5rem;
			}
			.book-description {
				color: rgb(var(--gray-dark));
			}
			.book-description p {
				margin: 0 0 0.85rem;
			}
			.chapter-list {
				display: grid;
				gap: 0.75rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.chapter-list a {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: 1rem;
				align-items: baseline;
				padding: 0.9rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				color: inherit;
				text-decoration: none;
			}
			.chapter-list a:hover h3,
			.chapter-list a:hover .chapter-number {
				color: rgb(var(--accent));
			}
			.chapter-number {
				color: rgb(var(--gray));
				font-weight: 700;
			}
			.chapter-list h3 {
				margin: 0 0 0.25rem;
				font-size: 1.2rem;
			}
			.chapter-list p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			@media (max-width: 720px) {
				.book-hero {
					grid-template-columns: 1fr;
				}
				.chapter-list a {
					grid-template-columns: 1fr;
					gap: 0.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="book-hero">
				<Image width={720} height={960} src={series.data.coverImage} alt="" />
				<div class="book-copy">
					<p>{chapters.length} phần</p>
					<h1>{series.data.title}</h1>
					<div class="book-description">
						<p>{series.data.description}</p>
						<Content />
					</div>
				</div>
			</section>

			<section>
				<h2>Mục lục</h2>
				<ul class="chapter-list">
					{
						chapters.map((chapter) => (
							<li>
								<a href={`/news/${chapter.id}/`}>
									<span class="chapter-number">
										{chapter.data.chapter === 0 ? 'Giới thiệu' : `Chương ${chapter.data.chapter}`}
									</span>
									<span>
										<h3>{chapter.data.title}</h3>
										<p>{chapter.data.description}</p>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

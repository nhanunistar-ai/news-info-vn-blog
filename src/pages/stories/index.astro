---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostMeta from '../../components/PostMeta.astro';
import { SITE_TITLE } from '../../consts';

const seriesEntries = (await getCollection('series')).sort((a, b) => a.data.order - b.data.order);
const storyPosts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'stories')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const chapterCounts = new Map<string, number>();
for (const post of storyPosts) {
	if (!post.data.series) continue;
	chapterCounts.set(post.data.series, (chapterCounts.get(post.data.series) ?? 0) + 1);
}

const standaloneStories = storyPosts.filter((post) => !post.data.series);
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead
			title={`Stories | ${SITE_TITLE}`}
			description="Cac truyen dai, series dich va bai viet dang cau chuyen tren news.info.vn."
		/>
		<style>
			main {
				width: min(1020px, calc(100% - 2em));
			}
			.page-title {
				margin-bottom: 1.5rem;
			}
			.page-title h1 {
				margin-bottom: 0.35rem;
			}
			.series-grid,
			.story-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.series-card,
			.story-card {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.series-card img,
			.story-card img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0.75rem;
			}
			.series-card:hover img,
			.story-card:hover img {
				box-shadow: var(--box-shadow);
			}
			.meta {
				margin: 0 0 0.25rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			h2 {
				margin-top: 2.5rem;
			}
			h3 {
				margin: 0 0 0.35rem;
				font-size: 1.35rem;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 720px) {
				.series-grid,
				.story-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-title">
				<h1>Stories</h1>
				<p>Truyện dài, series dịch và các bài viết nên đọc theo mạch câu chuyện.</p>
			</section>

			<section>
				<ul class="series-grid">
					{
						seriesEntries.map((series) => (
							<li>
								<a class="series-card" href={`/stories/${series.id}/`}>
									<Image width={720} height={360} src={series.data.coverImage} alt="" />
									<p class="meta">{chapterCounts.get(series.id) ?? 0} phần</p>
									<h3>{series.data.title}</h3>
									<p class="description">{series.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			{
				standaloneStories.length > 0 && (
					<section>
						<h2>Cau chuyen doc lap</h2>
						<ul class="story-grid">
							{standaloneStories.map((post) => (
								<li>
									<a class="story-card" href={`/news/${post.id}/`}>
										{post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
										<p class="meta">
											<PostMeta date={post.data.pubDate} postId={post.id} author={post.data.author} />
										</p>
										<h3>{post.data.title}</h3>
										<p class="description">{post.data.description}</p>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

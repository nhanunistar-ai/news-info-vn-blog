---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostMeta from '../../components/PostMeta.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featuredPost, ...listedPosts] = posts;

const getShortDescription = (description?: string) => {
	const text = (description ?? '').replace(/\s+/g, ' ').trim();
	if (!text) return '';

	const words = text.split(' ');
	let shortText = words.length > 20 ? words.slice(0, 20).join(' ') : text;

	if (shortText.length > 90) {
		const sliced = shortText.slice(0, 90).trim();
		shortText = sliced.replace(/\s+\S*$/, '').trim() || sliced;
	}

	return shortText.length < text.length ? `${shortText.replace(/[.,;:!?…]+$/, '')}...` : text;
};
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1020px, calc(100% - 2em));
			}
			.featured-card {
				display: block;
				margin-bottom: 2rem;
				color: inherit;
				text-align: center;
				text-decoration: none;
			}
			.featured-card * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.featured-card img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0.75rem;
			}
			.featured-title {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 2.369rem;
				line-height: 1;
			}
			.featured-card:hover img {
				box-shadow: var(--box-shadow);
			}
			.featured-card:hover .featured-title,
			.featured-card:hover .meta {
				color: rgb(var(--accent));
			}
			.story-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.story-card {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.story-card * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.story-card img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0.75rem;
			}
			.story-card:hover img {
				box-shadow: var(--box-shadow);
			}
			.meta {
				margin: 0 0 0.25rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			h3 {
				margin: 0 0 0.35rem;
				font-size: 1.35rem;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
			}
			.story-card:hover h3,
			.story-card:hover .meta {
				color: rgb(var(--accent));
			}
			@media (max-width: 720px) {
				.featured-title {
					font-size: 1.563em;
				}
				.story-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				{
					featuredPost && (
						<a class="featured-card" href={`/news/${featuredPost.id}/`}>
							{featuredPost.data.heroImage && (
								<Image width={1200} height={675} src={featuredPost.data.heroImage} alt="" />
							)}
							<h2 class="featured-title">{featuredPost.data.title}</h2>
							<p class="meta">
								<PostMeta
									date={featuredPost.data.pubDate}
									postId={featuredPost.id}
									author={featuredPost.data.author}
								/>
							</p>
						</a>
					)
				}
				<ul class="story-grid">
					{
						listedPosts.map((post) => (
							<li>
								<a class="story-card" href={`/news/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<p class="meta">
										<PostMeta date={post.data.pubDate} postId={post.id} author={post.data.author} />
									</p>
									<h3>{post.data.title}</h3>
									<p class="description">{getShortDescription(post.data.description)}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

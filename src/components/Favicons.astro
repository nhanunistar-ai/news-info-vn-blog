---
import favIcon from '~/assets/favicons/favicon.png';
import favIconLarge from '~/assets/favicons/favicon-logo.png';
import appleTouchIcon from '~/assets/favicons/apple-touch-icon.png';
---

<link rel="shortcut icon" href={favIcon.src} />
<link rel="icon" type="image/png" sizes="32x32" href={favIcon.src} />
<link rel="icon" type="image/png" sizes="192x192" href={favIconLarge.src} />
<link rel="mask-icon" href={favIconLarge.src} color="#F15A28" />
<link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
